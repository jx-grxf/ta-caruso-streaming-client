{
  "name": "caruso-reborn",
  "version": "0.2.1",
  "private": true,
  "author": "Johannes Grof",
  "license": "MIT",
  "type": "module",
  "main": "dist/electron/main.js",
  "description": "Local streaming hub for first-generation T+A Caruso devices with TuneIn and Deezer providers.",
  "keywords": [
    "caruso",
    "upnp",
    "dlna",
    "terminal-ui",
    "tunein",
    "internet-radio"
  ],
  "homepage": "https://github.com/jx-grxf/Caruso-Reborn",
  "bugs": {
    "url": "https://github.com/jx-grxf/Caruso-Reborn/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jx-grxf/Caruso-Reborn.git"
  },
  "scripts": {
    "assets:mac": "node scripts/generate-macos-assets.mjs",
    "quickstart": "npm run onboard",
    "onboard": "node scripts/dev-runner.mjs --watch false --entry src/onboard.ts",
    "dev": "node scripts/dev-runner.mjs",
    "dev:desktop": "npm run build && electron .",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "desktop": "npm run build && electron .",
    "check": "tsc --noEmit -p tsconfig.json",
    "pack:mac": "npm run assets:mac && npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir",
    "dist:mac": "npm run assets:mac && npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@fastify/static": "^9.0.0",
    "chalk": "^5.6.2",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "fast-xml-parser": "^5.5.9",
    "fastify": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "pino-pretty": "^13.0.0",
    "undici": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2"
  },
  "build": {
    "appId": "com.jxgrxf.carusoreborn",
    "productName": "Caruso Reborn Beta",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "ui/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/mac/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "background": "assets/mac/dmg-background.png",
      "icon": "assets/mac/icon.icns",
      "iconSize": 128,
      "window": {
        "width": 680,
        "height": 440
      },
      "contents": [
        {
          "x": 188,
          "y": 230,
          "type": "file"
        },
        {
          "x": 492,
          "y": 230,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jx-grxf",
        "repo": "Caruso-Reborn"
      }
    ]
  }
}
