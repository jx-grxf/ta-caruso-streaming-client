{
  "name": "ta-caruso-streaming-client",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "dist/electron/main.js",
  "description": "Local streaming bridge for T+A Caruso devices with TuneIn and Deezer providers.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:desktop": "npm run build && electron .",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "desktop": "npm run build && electron .",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^4.5.3",
    "fastify": "^5.2.1",
    "pino-pretty": "^13.0.0",
    "undici": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "electron": "^37.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
